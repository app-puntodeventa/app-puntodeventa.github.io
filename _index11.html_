<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>POS Pro 2.0 - Sistema de Ventas</title>

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcode.js/1.5.3/qrcode.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#111827">

<style>
  * {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  #loginScreen {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .login-card {
    background: white;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    padding: 2.5rem 1.5rem;
    width: 100%;
    max-width: 380px;
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .login-header i {
    font-size: 3rem;
    color: #667eea;
    margin-bottom: 0.5rem;
  }

  .login-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #111827;
    margin: 0;
  }

  .login-header p {
    color: #6b7280;
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  .pin-input {
    width: 100%;
    padding: 14px 44px 14px 14px;
    border: 2px solid #e5e7eb;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-align: center;
    transition: all 0.3s ease;
  }

  .pin-input:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .pin-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    font-size: 1.2rem;
  }

  .login-btn {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 1rem;
  }

  .login-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
  }

  .demo-hint {
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    padding: 10px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #92400e;
    margin-top: 1rem;
    display: none;
  }

  .demo-hint.show {
    display: block;
  }

  dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.6);
  }

  dialog {
    border-radius: 16px;
    padding: 0;
    max-width: 95vw;
    width: 100%;
    max-height: 95vh;
    overflow: auto !important;
  }

  @media (max-width: 640px) {
    dialog {
      width: 100vw;
      max-height: 100vh;
      border-radius: 0;
      margin: 0;
    }
  }

  .qr-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    background: white;
  }

  #qrCode {
    max-width: 250px;
    max-height: 250px;
  }
</style>

</head>

<body class="bg-gray-100 min-h-screen flex flex-col">

<!-- LOGIN SCREEN -->
<div id="loginScreen" class="fixed inset-0 flex items-center justify-center z-50 min-h-screen">
  <div class="login-card">
    <div class="login-header">
      <i class="bi bi-cash-register"></i>
      <h1>POS Pro 2.0</h1>
      <p>Sistema Inteligente de Ventas</p>
    </div>

    <div class="relative mb-4">
      <input id="pinInput"
        type="password"
        class="pin-input"
        placeholder="••••"
        maxlength="4"
        inputmode="numeric">
      <button id="togglePin" type="button" class="pin-toggle absolute">
        <i class="bi bi-eye"></i>
      </button>
    </div>

    <button id="btnLogin" class="login-btn">
      ▶ Ingresar
    </button>

    <div id="demoHint" class="demo-hint">
      💡 Demo: PIN <strong>4829</strong> (ADMIN)
    </div>

    <div class="text-center text-xs text-gray-500 mt-6 pt-4 border-t border-gray-200">
      <p>© 2024 POS Pro - Sistema Profesional</p>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="mainApp" class="hidden flex flex-col h-screen bg-gray-100 overflow-hidden">
  
  <!-- HEADER -->
  <header class="bg-gradient-to-r from-blue-600 to-blue-700 text-white p-4 shadow-lg flex-shrink-0 z-40">
    <div class="flex justify-between items-center gap-2">
      <div class="flex items-center gap-2 min-w-0">
        <i class="bi bi-cash-register text-xl flex-shrink-0"></i>
        <div class="min-w-0">
          <h1 class="font-bold text-lg truncate">POS Pro 2.0</h1>
          <p class="text-xs text-blue-100" id="userDisplay">Usuario: Admin</p>
        </div>
      </div>
      <button id="btnLogout" class="bg-red-500 hover:bg-red-600 text-white px-3 py-2 rounded-lg font-semibold transition flex-shrink-0 text-xs sm:text-sm">
        🚪 Salir
      </button>
    </div>
  </header>

  <!-- TOOLBAR -->
  <div class="bg-white border-b-2 border-gray-200 p-2 flex gap-2 flex-wrap flex-shrink-0 overflow-x-auto">
    <button id="btnNuevaVenta" class="bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-3 py-2 rounded-lg font-bold transition flex items-center gap-1 text-xs sm:text-sm flex-shrink-0 whitespace-nowrap">
      <i class="bi bi-plus-circle"></i> <span class="hidden sm:inline">Nueva Venta</span>
    </button>
    <a href="inventario.html" class="bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white px-3 py-2 rounded-lg font-bold transition flex items-center gap-1 text-xs sm:text-sm flex-shrink-0 whitespace-nowrap">
      <i class="bi bi-box"></i> <span class="hidden sm:inline">Inventario</span>
    </a>
    <a href="ganancias.html" class="bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white px-3 py-2 rounded-lg font-bold transition flex items-center gap-1 text-xs sm:text-sm flex-shrink-0 whitespace-nowrap">
      <i class="bi bi-graph-up"></i> <span class="hidden sm:inline">Ganancias</span>
    </a>
  </div>

  <!-- RESUMEN DÍA -->
  <div class="bg-gradient-to-r from-blue-50 to-blue-100 border-b-2 border-blue-200 p-2 sm:p-4 flex-shrink-0 overflow-x-auto">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 min-w-full">
      <div class="bg-white p-2 sm:p-3 rounded-lg shadow-sm">
        <p class="text-xs text-gray-600 font-semibold">VENTAS</p>
        <p id="statVentas" class="text-xl sm:text-2xl font-bold text-blue-600">0</p>
      </div>
      <div class="bg-white p-2 sm:p-3 rounded-lg shadow-sm">
        <p class="text-xs text-gray-600 font-semibold">TOTAL</p>
        <p id="statTotal" class="text-xl sm:text-2xl font-bold text-green-600">$0</p>
      </div>
      <div class="bg-white p-2 sm:p-3 rounded-lg shadow-sm">
        <p class="text-xs text-gray-600 font-semibold">INGRESOS</p>
        <p id="statIngresos" class="text-xl sm:text-2xl font-bold text-purple-600">$0</p>
      </div>
      <div class="bg-white p-2 sm:p-3 rounded-lg shadow-sm">
        <p class="text-xs text-gray-600 font-semibold">GANANCIA</p>
        <p id="statGanancia" class="text-xl sm:text-2xl font-bold text-orange-600">$0</p>
      </div>
    </div>
  </div>

  <!-- HISTORIAL VENTAS -->
  <div id="listaVentas" class="flex-1 overflow-y-auto p-2 sm:p-4 space-y-3"></div>

</div>

<!-- MODAL VENTA -->
<dialog id="modalVenta" class="w-full sm:max-w-2xl">
  <div class="flex flex-col h-screen sm:h-auto max-h-screen sm:max-h-[95vh]">
    
    <!-- HEADER MODAL -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white p-3 sm:p-4 flex justify-between items-center flex-shrink-0 sticky top-0 z-10">
      <h2 class="font-bold text-base sm:text-xl flex items-center gap-2 truncate">
        <i class="bi bi-receipt"></i> <span>Nueva Venta</span>
      </h2>
      <button onclick="document.getElementById('modalVenta').close()" class="text-2xl hover:opacity-75 transition flex-shrink-0">✕</button>
    </div>

    <!-- CONTENIDO SCROLLABLE -->
    <div class="flex-1 overflow-y-auto modal-body-scroll p-3 sm:p-4">
      <!-- TABS -->
      <div class="flex gap-1 mb-4 border-b-2 border-gray-200 pb-2 overflow-x-auto sticky top-0 bg-white z-10">
        <button class="tabVenta px-3 sm:px-4 py-2 font-bold border-b-4 border-blue-500 text-blue-600 transition active-tab whitespace-nowrap text-sm sm:text-base" data-tab="catalogo">
          📦 Catálogo
        </button>
        <button class="tabVenta px-3 sm:px-4 py-2 font-bold border-b-4 border-transparent hover:text-blue-600 transition whitespace-nowrap text-sm sm:text-base" data-tab="manual">
          ✏️ Manual
        </button>
        <button class="tabVenta px-3 sm:px-4 py-2 font-bold border-b-4 border-transparent hover:text-blue-600 transition whitespace-nowrap text-sm sm:text-base" data-tab="rapido">
          ⚡ Rápido
        </button>
      </div>

      <!-- TAB: CATÁLOGO -->
      <div id="tabCatalogo" class="tabContent space-y-3">
        <div>
          <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">🔍 Buscar Producto</label>
          <input id="searchProd" type="text" placeholder="Ej: Huevo, Pan, etc..." 
            class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
        </div>
        <div>
          <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">📋 Selecciona</label>
          <select id="selectProd" class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
            <option value="">-- Selecciona un producto --</option>
          </select>
        </div>
        <div>
          <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">🔢 Cantidad</label>
          <input id="cantidadCat" type="number" min="1" value="1" 
            class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
        </div>
        <div id="previewCat" class="p-2 sm:p-3 bg-blue-50 rounded-lg border-l-4 border-blue-500 text-xs sm:text-sm"></div>
        <button id="btnAgrCat" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 sm:py-3 rounded-lg transition text-sm sm:text-base">➕ Agregar</button>
      </div>

      <!-- TAB: MANUAL -->
      <div id="tabManual" class="tabContent hidden space-y-3">
        <div>
          <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">📝 Nombre Producto</label>
          <input id="nombrMan" type="text" placeholder="Ej: Café, Refresco, etc..." 
            class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">🔢 Cantidad</label>
            <input id="cantidadMan" type="number" min="1" value="1" 
              class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
          </div>
          <div>
            <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">💰 Precio ($)</label>
            <input id="precioMan" type="number" min="0" step="0.01" 
              class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base">
          </div>
        </div>
        <div id="previewMan" class="p-2 sm:p-3 bg-green-50 rounded-lg border-l-4 border-green-500 text-xs sm:text-sm"></div>
        <button id="btnAgrMan" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 sm:py-3 rounded-lg transition text-sm sm:text-base">✨ Agregar</button>
      </div>

      <!-- TAB: RÁPIDO -->
      <div id="tabRapido" class="tabContent hidden space-y-3">
        <div class="p-2 sm:p-3 bg-yellow-50 border-l-4 border-yellow-500 text-xs rounded max-h-32 overflow-y-auto">
          <p class="font-bold mb-1">📋 Ejemplos:</p>
          <ul class="space-y-0.5 text-xs">
            <li>• "5" = $5</li>
            <li>• "4 5" = 4×$5 = $20</li>
            <li>• "4 panes 5" = 4 panes × $5</li>
            <li>• "2 litros de leche" = 2 lt</li>
          </ul>
        </div>
        <div>
          <label class="block text-xs sm:text-sm font-bold text-gray-700 mb-2">⚡ Descripción Rápida</label>
          <input id="inputRapido" type="text" placeholder="Ej: 4 panes 5..." 
            class="w-full p-2 sm:p-3 border-2 border-gray-300 rounded-lg focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition text-sm sm:text-base"
            onkeypress="if(event.key==='Enter') document.getElementById('btnAgrRap').click()">
        </div>
        <div id="previewRap" class="p-2 sm:p-3 bg-purple-50 rounded-lg border-l-4 border-purple-500 text-xs sm:text-sm hidden max-h-20 overflow-y-auto"></div>
        <button id="btnAgrRap" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 sm:py-3 rounded-lg transition text-sm sm:text-base">⚡ Agregar</button>
      </div>

      <!-- CARRITO SECTION -->
      <div class="mt-6 border-t pt-3">
        <h3 class="font-bold text-base sm:text-lg flex items-center gap-2">
          🛒 Carrito (<span id="conteoCart">0</span>)
        </h3>
      </div>
      
      <div id="carrito" class="space-y-2 mt-2 bg-gray-50 p-2 rounded-lg max-h-40 overflow-y-auto">
        <p class="text-center text-gray-400 text-xs sm:text-sm py-3">Carrito vacío</p>
      </div>

      <!-- ESPACIO PARA EL BOTÓN FLOTANTE EN MOBILE -->
      <div class="h-32 sm:h-0"></div>
    </div>

    <!-- BOTÓN FINALIZAR - MEJORADO -->
    <div class="fixed bottom-0 left-0 right-0 sm:static sm:flex-shrink-0 bg-white border-t-4 border-blue-200 p-3 sm:p-4 space-y-3 shadow-2xl z-50">
      <div class="bg-gradient-to-r from-blue-50 to-blue-100 p-2 sm:p-3 rounded-lg border-2 border-blue-300">
        <p class="text-gray-600 text-xs sm:text-sm mb-1">Total a pagar:</p>
        <p id="totalCar" class="text-2xl sm:text-3xl font-bold text-blue-600">$0.00</p>
      </div>
      <button id="btnFinalizarVenta" class="w-full bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 text-white font-bold py-3 sm:py-4 rounded-lg transition transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2 text-sm sm:text-base">
        <i class="bi bi-check-circle"></i> Finalizar Venta
      </button>
    </div>
  </div>
</dialog>

<!-- MODAL COMPROBANTE Y QR -->
<dialog id="modalComprobante" class="w-full sm:max-w-lg">
  <div class="bg-white rounded-xl p-4 sm:p-6 space-y-4 max-h-[95vh] overflow-y-auto">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg sm:text-xl font-bold text-gray-800">🧾 Comprobante de Venta</h2>
      <button onclick="document.getElementById('modalComprobante').close()" class="text-2xl hover:opacity-75">✕</button>
    </div>
    
    <!-- COMPROBANTE -->
    <div id="comprobante" class="bg-gray-50 p-3 sm:p-4 rounded-lg border-2 border-gray-200 text-xs sm:text-sm font-mono whitespace-pre-wrap max-h-40 overflow-y-auto">
      Cargando...
    </div>

    <!-- QR -->
    <div class="bg-white p-4 rounded-lg border-2 border-gray-200 flex flex-col items-center">
      <p class="text-sm font-bold mb-2 text-gray-700">Código QR:</p>
      <div id="qrCode" class="qr-container"></div>
    </div>

    <!-- BOTONES ACCIÓN -->
    <div class="grid grid-cols-2 gap-3">
      <button onclick="compartirWhatsApp()" class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 sm:py-3 rounded-lg transition flex items-center justify-center gap-2 text-xs sm:text-sm">
        <i class="bi bi-whatsapp"></i> WhatsApp
      </button>
      <button onclick="descargarQR()" class="bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 sm:py-3 rounded-lg transition flex items-center justify-center gap-2 text-xs sm:text-sm">
        <i class="bi bi-download"></i> QR
      </button>
    </div>

    <button onclick="document.getElementById('modalComprobante').close(); document.getElementById('modalVenta').close();" class="w-full bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 sm:py-3 rounded-lg transition">
      Cerrar
    </button>
  </div>
</dialog>

<script src="parser11.js"></script>
<script src="app11.js"></script>

</body>
</html>